---
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';
import { ArrowRight } from 'lucide-react';

const steps = [
  { n: '01', title: 'Get a quote in 60 seconds', body: 'Tell us your pool size, suburb, and how often. We\'ll give you a fixed price — no callout fee, no "depends on the day".' },
  { n: '02', title: 'We schedule your tech', body: 'You get the same tech every visit. They\'ll send an SMS the night before with their ETA window — usually 90 minutes wide, not all day.' },
  { n: '03', title: 'Photo log after every visit', body: 'Skimming, vacuuming, water test results, chemicals dosed, photos of the pool clean. Emailed before they leave the driveway.' },
];
---

<section id="how-it-works" class="py-24 bg-gradient-to-b from-background to-aqua-soft/30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl space-y-4 mb-12">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-aqua">
        <span class="h-px w-8 bg-aqua"></span>
        How it works
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-semibold text-deep">
        From quote to crystal-clear in a week
      </h2>
      <p class="text-lg text-ink-soft leading-relaxed">
        No "we'll get back to you," no surprise callout fees. Three steps and you're sorted.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {steps.map((s, i) => (
        <div key={s.n} class="relative">
          <Card className="h-full">
            <CardHeader>
              <div class="font-mono text-sm text-aqua font-semibold mb-3">{s.n}</div>
              <CardTitle class="font-display text-2xl text-deep leading-tight">{s.title}</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-ink-soft leading-relaxed">{s.body}</p>
            </CardContent>
          </Card>
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute top-12 -right-3 z-10 h-6 w-6 items-center justify-center rounded-full bg-background border border-border shadow-sm">
              <ArrowRight className="h-3 w-3 text-aqua" />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>