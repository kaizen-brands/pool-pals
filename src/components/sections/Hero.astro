---
---

<section id="top" class="relative pt-8 pb-20 overflow-hidden">
  <!-- Shimmer background -->
  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 50% at 50% 0%, oklch(0.62 0.13 215 / 0.18), transparent 60%), radial-gradient(ellipse 60% 40% at 90% 80%, oklch(0.78 0.13 75 / 0.12), transparent 60%);">
  </div>

  <div class="container-main relative">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-14 items-center">
      <!-- Text content -->
      <div class="animate-[fade-up_0.6s_ease_both]">
        <div class="pill-tag mb-5">
          <span class="live-dot"></span>
          Servicing 1,400+ Gold Coast pools weekly
        </div>

        <h1 class="font-display text-[clamp(48px,6vw,84px)] leading-[1.02] tracking-tight mb-5">
          Sparkling pools.
          <br />
          <span class="text-aqua-deep italic">Without lifting a net.</span>
        </h1>

        <p class="text-lg leading-relaxed text-ink-soft max-w-[540px] mb-8">
          Reliable weekly pool cleaning across the Gold Coast — same friendly
          technician, transparent pricing, and a sparkling pool every Friday.
          No contracts, no surprises.
        </p>

        <div class="flex gap-3 mb-8 flex-wrap">
          <button class="btn btn-aqua btn-lg" data-action="quote">
            Get instant quote
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </button>
          <a class="btn btn-ghost btn-lg" href="#pricing">
            See pricing
          </a>
        </div>

        <div class="flex gap-7 items-center flex-wrap pt-5 border-t border-[var(--color-hairline)]">
          <div class="flex items-center gap-2.5">
            <span class="flex gap-0.5 text-[var(--color-sun)]">
              {Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
                  <path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.6L6 22l1.5-7.2L2 10l7.1-1.1L12 2z"/>
                </svg>
              ))}
            </span>
            <span class="text-sm text-ink-soft">
              <strong class="text-[var(--color-ink)]">4.9</strong> · 312 Google reviews
            </span>
          </div>

          <div class="flex items-center gap-2 text-sm text-ink-soft">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-[var(--color-aqua)]">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Fully insured · ABN 41 638 902 117
          </div>

          <div class="flex items-center gap-2 text-sm text-ink-soft">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-[var(--color-aqua)]">
              <rect x="3" y="5" width="18" height="16" rx="2"/>
              <path d="M8 3v4M16 3v4M3 10h18"/>
            </svg>
            Est. 2025
          </div>
        </div>
      </div>

      <!-- Hero visual -->
      <div class="animate-[fade-up_0.6s_ease_both] [animation-delay:0.1s] relative">
        <div class="relative aspect-[4/5] max-w-[480px] mx-auto">
          <!-- Main pool image -->
          <div class="absolute inset-0 rounded-[22px] overflow-hidden shadow-pp-lg bg-aqua-soft">
            <img
              src="/images/hero-pool.png"
              alt="Crystal clear swimming pool in a Gold Coast backyard"
              class="w-full h-full object-cover opacity-0 transition-opacity duration-700"
              loading="eager"
              width="480"
              height="600"
              onload="this.classList.remove('opacity-0')"
            />
            <!-- Surface highlight -->
            <div class="absolute top-0 left-0 right-0 h-[30%]"
              style="background: linear-gradient(180deg, rgba(255,255,255,0.18), transparent);">
            </div>
          </div>

          <!-- Floating chip — last service -->
          <div class="absolute top-7 -left-7 bg-white rounded-[14px] p-3.5 shadow-pp-md border border-[var(--color-hairline)] flex items-center gap-3 min-w-[240px] hidden md:flex">
            <div class="w-10 h-10 rounded-[10px] bg-aqua-soft flex items-center justify-center text-[var(--color-aqua-deep)] shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M4 12.5l5 5L20 6.5"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold">Cleaned Friday 8:42am</div>
              <div class="text-xs text-ink-mute">pH 7.4 · Chlorine 2.1ppm · Skimmer cleared</div>
            </div>
          </div>

          <!-- Floating chip — price -->
          <div class="absolute bottom-8 -right-6 bg-white rounded-[14px] p-3.5 pr-4 shadow-pp-md border border-[var(--color-hairline)] min-w-[200px] hidden md:block">
            <div class="text-[11px] text-ink-mute tracking-widest uppercase mb-1">Weekly plan from</div>
            <div class="flex items-baseline gap-1">
              <span class="font-display text-[38px] leading-none tabular-nums">$45</span>
              <span class="text-sm text-ink-mute">/visit</span>
            </div>
            <div class="text-[11px] text-[var(--color-success)] font-medium mt-0.5">✓ All chemicals included</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
