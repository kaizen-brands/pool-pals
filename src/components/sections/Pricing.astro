---
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Check, Shield, ArrowRight } from 'lucide-react';

const tiers = [
  {
    name: 'Splash',
    price: 45,
    freq: 'per visit · fortnightly',
    tag: null,
    desc: 'For pools that just need to stay swim-ready. The basics, done right, every week.',
    features: ['30-min visit', 'Skim, brush, vacuum', 'Basic water test (5 markers)', 'Chemical top-up', 'Email log after every visit'],
    cta: 'Choose Splash',
    featured: false,
  },
  {
    name: 'Crystal',
    price: 55,
    freq: 'per visit · weekly',
    tag: 'Most popular',
    desc: 'Our most popular plan. Everything in Splash + the deeper diagnostics most pools need on the Coast.',
    features: ['45-min visit', 'Everything in Splash', '11-point water test', 'Salt cell + pump check', 'Phosphate dosing included', 'Priority booking + same-week call-outs'],
    cta: 'Choose Crystal',
    featured: true,
  },
  {
    name: 'Concierge',
    price: 89,
    freq: 'per visit · twice weekly',
    tag: 'Concierge',
    desc: 'White-glove service for show-home pools, holiday rentals, and pools that get a lot of attention.',
    features: ['60-min visit', 'Everything in Crystal', 'Tile & waterline scrub', 'Filter deep-clean (monthly)', 'Equipment performance report (quarterly)', 'Same-day call-out included'],
    cta: 'Talk to us',
    featured: false,
  },
];
---

<section id="pricing" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl space-y-4 mb-12 mx-auto text-center">
      <div class="flex items-center justify-center gap-2 text-xs font-mono uppercase tracking-widest text-aqua">
        <span class="h-px w-8 bg-aqua"></span>
        Pricing
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-semibold text-deep">
        Simple plans. Real prices.
      </h2>
      <p class="text-lg text-ink-soft leading-relaxed">
        No callout fees. No "depends on the day." Cancel any time with 14 days' notice.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {tiers.map((t) => (
        <div key={t.name} class={`relative rounded-xl border bg-card text-card-foreground shadow-sm flex flex-col p-6 ${t.featured ? 'border-aqua border-2 shadow-xl scale-[1.02]' : ''}`}>
          {t.tag && (
            <Badge class={`absolute -top-3 left-1/2 -translate-x-1/2 ${t.featured ? 'bg-aqua text-white' : 'bg-deep text-white'}`}>
              {t.tag}
            </Badge>
          )}
          <div class="mb-4">
            <h3 class="font-display text-2xl text-deep font-semibold">{t.name}</h3>
            <p class="text-ink-soft text-sm leading-relaxed pt-1">{t.desc}</p>
            <div class="pt-4 flex items-baseline gap-1.5">
              <span class="font-display text-5xl font-semibold text-deep">${t.price}</span>
              <span class="text-sm text-ink-mute">{t.freq}</span>
            </div>
          </div>
          <div class="flex-1">
            <div class="h-px w-full bg-border mb-5"></div>
            <ul class="space-y-3">
              {t.features.map((f) => (
                <li key={f} class="flex items-start gap-2.5 text-sm text-ink-soft">
                  <Check className="h-4 w-4 text-success mt-0.5 shrink-0" />
                  {f}
                </li>
              ))}
            </ul>
          </div>
          <div class="mt-6">
            <Button
              data-action="quote"
              variant={t.featured ? 'default' : 'outline'}
              className="w-full"
              size="lg"
            >
              {t.cta}
              <ArrowRight className="h-4 w-4" />
            </Button>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 flex items-center justify-center gap-2 text-sm text-ink-mute">
      <Shield className="h-4 w-4" />
      All plans include public liability insurance ($20M) and a 14-day satisfaction guarantee
    </div>
  </div>
</section>