---
const stats = [
  { n: '5★', label: 'Our service standard', sub: 'we aim for, every visit' },
  { n: '100%', label: 'Licensed & insured', sub: 'QBCC + $20m liability' },
  { n: '<24h', label: 'Quote turnaround', sub: 'weekdays, often <2h' },
  { n: '12mo', label: 'Workmanship warranty', sub: 'on every repair' },
];
---

<section class="border-y border-border bg-card">
  <div class="mx-auto max-w-7xl px-6 py-12 grid grid-cols-2 lg:grid-cols-4 gap-8">
    {stats.map((s) => (
      <div class="space-y-1">
        <div class="font-display text-4xl md:text-5xl font-semibold text-deep tabular">{s.n}</div>
        <div class="text-sm font-medium text-foreground">{s.label}</div>
        <div class="text-xs text-ink-mute">{s.sub}</div>
      </div>
    ))}
  </div>
</section>