---
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { 
  Filter, 
  FlaskConical, 
  Leaf, 
  SlidersHorizontal, 
  Calendar, 
  ShieldCheck,
  Check,
  ArrowRight
} from 'lucide-react';

const services = [
  {
    icon: Filter,
    title: 'Weekly Pool Service',
    price: 'from $55/wk',
    blurb: 'Skim, vacuum, brush, basket clear, water test & dose, equipment check. The whole nine.',
    includes: ['Surface skim & wall brush', 'Vacuum & basket clear', '11-point water test', 'Chemical dose & log'],
  },
  {
    icon: FlaskConical,
    title: 'Chemical Balancing',
    price: 'from $35',
    blurb: 'Lab-grade test on 11 markers. Calibrated dosing, written log, photo proof.',
    includes: ['pH, chlorine, alkalinity', 'Calcium hardness, CYA', 'Phosphate & metals', 'Photo + email log'],
  },
  {
    icon: Leaf,
    title: 'Green Pool Recovery',
    price: 'from $290',
    blurb: 'Algae, black water, post-storm sludge — back to swim-ready in 3–5 days, fixed price.',
    includes: ['Initial shock & flocc', 'Daily checks for 5 days', 'Filter deep clean', 'Crystal-clear guarantee'],
  },
  {
    icon: SlidersHorizontal,
    title: 'Equipment & Repairs',
    price: 'quoted',
    blurb: 'Pumps, filters, salt cells, heaters, chlorinators. Diagnose, quote, fix.',
    includes: ['Same-day diagnostics', 'Genuine parts only', '12-month workmanship', 'Authorised on Astralpool, Davey, Zodiac'],
  },
  {
    icon: Calendar,
    title: 'Holiday & Airbnb',
    price: 'from $75/visit',
    blurb: 'Turnover-aligned visits for short-stay rentals. Photo report after every clean.',
    includes: ['Same-day-as-checkout slots', 'Guest-ready photo report', 'Towel + chair reset (opt)', 'Owner SMS confirmation'],
  },
  {
    icon: ShieldCheck,
    title: 'Compliance Inspections',
    price: '$185',
    blurb: 'Pre-sale or rental certificate inspections. QBCC-licensed inspectors, full report.',
    includes: ['Form 23 issued', 'Lodged with QBCC', 'Re-inspection included', '5-day turnaround'],
  },
];
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl space-y-4 mb-12">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-aqua">
        <span class="h-px w-8 bg-aqua"></span>
        What we do
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-semibold text-deep">
        Pool care that actually shows up
      </h2>
      <p class="text-lg text-ink-soft leading-relaxed">
        Six services covering every Coast pool — from twice-weekly Airbnb turnovers to compliance certificates for sale settlements.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s) => {
        const Icon = s.icon;
        return (
          <div class="group rounded-xl border bg-card text-card-foreground shadow-sm hover:border-aqua/50 hover:shadow-md transition-all p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="h-12 w-12 rounded-lg bg-aqua-soft flex items-center justify-center text-aqua-deep group-hover:bg-aqua group-hover:text-white transition-colors">
                <Icon className="h-6 w-6" />
              </div>
              <Badge variant="outline" className="font-mono text-xs">{s.price}</Badge>
            </div>
            <h3 class="font-display text-2xl font-semibold text-deep mb-1">{s.title}</h3>
            <p class="text-base text-ink-soft pt-1 mb-4">{s.blurb}</p>
            <ul class="space-y-2 mb-5">
              {s.includes.map((it) => (
                <li class="flex items-start gap-2 text-sm text-ink-soft">
                  <Check className="h-4 w-4 text-success mt-0.5 shrink-0" />
                  {it}
                </li>
              ))}
            </ul>
            <button 
              data-action="quote"
              class="inline-flex items-center gap-1 text-sm font-medium text-aqua-deep hover:text-aqua transition-colors"
            >
              Get a quote <ArrowRight className="h-4 w-4" />
            </button>
          </div>
        );
      })}
    </div>
  </div>
</section>