---
const suburbs = [
  'Surfers Paradise', 'Broadbeach', 'Mermaid Beach', 'Nobby Beach',
  'Miami', 'Burleigh Heads', 'Palm Beach', 'Currumbin',
  'Tugun', 'Coolangatta', 'Kirra', 'Bilinga',
  'Robina', 'Varsity Lakes', 'Reedy Creek', 'Mudgeeraba',
  'Bundall', 'Benowa', 'Ashmore', 'Carrara',
  'Helensvale', 'Hope Island', 'Paradise Point', 'Runaway Bay',
  'Southport', 'Labrador', 'Biggera Waters', 'Coombabah',
];
---

<section id="service-area" class="py-24">
  <div class="container-main">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="section-eyebrow eyebrow"><span class="dot"></span>Where we work</div>
        <h2 class="font-display text-[clamp(36px,4.5vw,56px)] leading-none mb-5">
          From <span class="text-aqua-deep italic">Coolangatta</span> to <span class="text-aqua-deep italic">Hope Island</span>.
        </h2>
        <p class="text-[17px] text-ink-soft mb-8 max-w-[480px]">
          We service every suburb on the Gold Coast — from the high-rises along the strip to the
          acreage in the hinterland. If you've got a pool, we can get to it.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-2 text-sm text-ink-soft">
          {suburbs.map((s) => (
            <div class="flex items-center gap-1.5">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-[var(--color-success)] shrink-0">
                <path d="M4 12.5l5 5L20 6.5"/>
              </svg>
              {s}
            </div>
          ))}
        </div>
        <div class="mt-6 text-sm text-ink-mute">
          Don't see your suburb? <a href="#cta" class="text-[var(--color-aqua-deep)] underline underline-offset-[3px]">Just ask</a> — we probably cover it.
        </div>
      </div>

      <!-- Map -->
      <div class="relative aspect-[1/1.1] rounded-[22px] overflow-hidden border border-[var(--color-hairline)]"
        style="background: linear-gradient(180deg, oklch(0.97 0.02 215), oklch(0.94 0.03 215));">
        <svg viewBox="0 0 400 440" class="absolute inset-0 w-full h-full">
          <!-- Ocean -->
          <rect width="400" height="440" fill="oklch(0.86 0.06 215)" />
          <!-- Land — stylised Gold Coast outline -->
          <path
            d="M 60 0 L 220 0 L 230 30 L 215 70 L 240 100 L 220 140 L 245 180 L 220 220 L 250 260 L 230 300 L 260 340 L 230 380 L 250 440 L 0 440 L 0 0 Z"
            fill="oklch(0.96 0.01 90)"
            stroke="oklch(0.85 0.02 90)"
            stroke-width="1"
          />
          <!-- Beach line -->
          <path
            d="M 220 0 L 230 30 L 215 70 L 240 100 L 220 140 L 245 180 L 220 220 L 250 260 L 230 300 L 260 340 L 230 380 L 250 440"
            stroke="oklch(0.78 0.08 80)" stroke-width="2" fill="none" stroke-dasharray="2 4" opacity="0.5"
          />
          <!-- Pin dots — service locations -->
          {[
            [200, 50], [195, 110], [215, 165], [200, 200], [220, 240],
            [195, 285], [225, 320], [210, 360], [225, 400],
            [150, 90], [120, 140], [140, 200], [110, 250], [160, 300],
            [80, 180], [90, 320],
          ].map(([x, y]) => (
            <g>
              <circle cx={x} cy={y} r="6" fill="var(--color-aqua)" opacity="0.2" />
              <circle cx={x} cy={y} r="3" fill="var(--color-aqua-deep)" />
            </g>
          ))}
          <!-- HQ pin -->
          <g>
            <circle cx="195" cy="200" r="14" fill="var(--color-aqua)" opacity="0.15" />
            <circle cx="195" cy="200" r="9" fill="var(--color-aqua)" opacity="0.3" />
            <circle cx="195" cy="200" r="5" fill="var(--color-ink)" />
            <text x="210" y="204" font-size="11" font-family="Inter" font-weight="600" fill="var(--color-ink)">HQ — Miami</text>
          </g>
          <!-- Region labels -->
          <text x="40" y="60" font-size="9" font-family="JetBrains Mono" fill="oklch(0.5 0.05 90)" letter-spacing="1.5">NORTHERN BEACHES</text>
          <text x="40" y="220" font-size="9" font-family="JetBrains Mono" fill="oklch(0.5 0.05 90)" letter-spacing="1.5">CENTRAL</text>
          <text x="40" y="380" font-size="9" font-family="JetBrains Mono" fill="oklch(0.5 0.05 90)" letter-spacing="1.5">SOUTHERN</text>
          <text x="290" y="220" font-size="11" font-family="Instrument Serif" font-style="italic" fill="oklch(0.4 0.08 220)">Pacific</text>
        </svg>
        <div class="absolute top-4 left-4 bg-white px-3 py-2 rounded-[10px] shadow-pp-sm text-xs flex items-center gap-2">
          <span class="w-2 h-2 bg-[var(--color-aqua-deep)] rounded-full"></span>
          <span><strong>27</strong> suburbs covered</span>
        </div>
      </div>
    </div>
  </div>
</section>
