---
const faqs = [
  {
    q: 'How much does a regular pool clean cost on the Gold Coast?',
    a: 'Most homes pay between $45 and $75 per visit, depending on pool size, frequency, and any extras (heating, salt, water features). Our standard \'Crystal\' plan — covering 90% of suburban pools — is $55/week with all chemicals included. No setup fee, no contract.',
  },
  {
    q: 'How often does my pool actually need cleaning?',
    a: "In Queensland's climate, most pools need a weekly clean from October to April, and fortnightly in the cooler months. We auto-adjust your schedule with the seasons — you'll get more visits when you need them, fewer when you don't.",
  },
  {
    q: 'Do I need to be home during the service?',
    a: "Nope. As long as we can access your pool gate or have a side-gate code, you can be at work, the beach, or interstate. We send a photo report and water-test summary after every visit.",
  },
  {
    q: 'What chemicals do you use? Are they safe for kids and pets?',
    a: 'We only use TGA-approved sanitisers, balanced to Australian Standard AS3633. Everything is safe to swim in within 30 minutes of treatment. We\'ll always tell you ahead of any heavier treatment (like a shock dose).',
  },
  {
    q: 'What if my pool turns green between visits?',
    a: 'Crystal and Concierge plans include free emergency rescue calls — we\'ll be there within 48 hours. If we caused it, we fix it free. If it was a storm or party, we charge a flat $129 recovery fee, all chemicals included.',
  },
  {
    q: 'Is there a contract or lock-in?',
    a: 'Never. You can cancel, pause, or change plans any time via text, email, or the customer dashboard. Most clients stay with us for years — but only because they want to.',
  },
  {
    q: 'Do you service apartment-block or commercial pools?',
    a: 'Yes. We currently maintain 40+ strata and short-stay rental pools across the Coast. Ask about our commercial rates — typically 15–20% lower per visit at scale.',
  },
];
---

<section id="faq" class="bg-[var(--color-bg-alt)] py-24">
  <div class="container-narrow">
    <div class="text-center mb-14">
      <div class="section-eyebrow eyebrow justify-center"><span class="dot"></span>Common questions</div>
      <h2 class="font-display text-[clamp(36px,4.5vw,56px)] leading-none">
        Things people <span class="text-aqua-deep italic">actually ask.</span>
      </h2>
    </div>

    <div class="border-t border-[var(--color-hairline)]">
      {faqs.map((faq, i) => (
        <details class="group border-b border-[var(--color-hairline)]" key={i}>
          <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer list-none text-left text-lg font-medium hover:text-[var(--color-aqua-deep)] transition-colors select-none">
            <span>{faq.q}</span>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 shrink-0 text-ink-mute transition-transform group-open:rotate-45"
            >
              <path d="M12 5v14M5 12h14" />
            </svg>
          </summary>
          <div class="pb-6 text-base text-ink-soft leading-relaxed pr-12">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <div class="text-center mt-12 text-sm text-ink-soft">
      Still curious? Call us — <a href="tel:1300766572" class="font-medium underline underline-offset-[3px]">1300 POOL PAL</a> — a real person picks up.
    </div>
  </div>
</section>
