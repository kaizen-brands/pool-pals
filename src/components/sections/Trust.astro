---
const items = [
  { icon: 'shield', h: '$20m public liability', d: 'Full insurance, certificate available on request.' },
  { icon: 'check', h: 'Police-checked techs', d: 'Every team member background-checked annually.' },
  { icon: 'calendar', h: 'Gold Coast born & run', d: 'Locally owned and operated — we live where we work.' },
  { icon: 'drop', h: '30-day money back', d: 'First-month satisfaction guarantee, no questions.' },
];
---

<section class="bg-[var(--color-bg-alt)] py-[72px]">
  <div class="container-main">
    <div class="grid grid-cols-2 lg:grid-cols-4">
      {items.map((it, i) => (
        <div class={`p-2 px-7 ${i > 0 ? 'lg:border-l border-[var(--color-hairline)]' : ''} ${i > 1 ? 'border-t lg:border-t-0 pt-6 lg:pt-2' : ''} ${i % 2 === 1 ? 'border-l lg:border-l' : ''}`}>
          {it.icon === 'shield' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[var(--color-aqua-deep)] mb-3">
               <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
             </svg>
           )}
           {it.icon === 'check' && (
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[var(--color-aqua-deep)] mb-3">
               <path d="M4 12.5l5 5L20 6.5"/>
             </svg>
           )}
           {it.icon === 'calendar' && (
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[var(--color-aqua-deep)] mb-3">
               <rect x="3" y="5" width="18" height="16" rx="2"/>
               <path d="M8 3v4M16 3v4M3 10h18"/>
             </svg>
           )}
           {it.icon === 'drop' && (
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[var(--color-aqua-deep)] mb-3">
              <path d="M12 2.7l5.5 7.5a7 7 0 11-11 0L12 2.7z"/>
            </svg>
          )}
          <div class="text-[15px] font-semibold mb-1.5">{it.h}</div>
          <div class="text-sm text-ink-soft leading-relaxed">{it.d}</div>
        </div>
      ))}
    </div>
  </div>
</section>
