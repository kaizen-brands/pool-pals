---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'About Pool Pals — Gold Coast Pool Cleaning Since 2025';
const description = 'Pool Pals is a locally owned, fully insured Gold Coast pool care company founded in 2025 by two locals who were tired of unreliable pool guys. Meet the team behind the net.';
---

<BaseLayout title={title} description={description}>
  <section class="pt-16 pb-12">
    <div class="container-narrow">
      <div class="section-eyebrow eyebrow"><span class="dot"></span>About us</div>
      <h1 class="font-display text-[clamp(40px,5vw,72px)] leading-[1.02] mb-6">
        Two mates with a <span class="text-aqua-deep italic">mission.</span>
      </h1>
      <p class="text-lg text-ink-soft leading-relaxed max-w-[640px] mb-12">
        Pool Pals started in 2025 when two Gold Coast locals — tired of unreliable pool guys who showed up
        late, charged hidden fees, and left pools murky — decided to do it properly.
      </p>
    </div>
  </section>

  <!-- Story grid -->
  <section class="pb-20">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-10 mb-16">
        <div class="card p-8">
          <h2 class="font-display text-[28px] leading-tight mb-3">Why we started</h2>
          <p class="text-ink-soft leading-relaxed">
            After years of watching neighbours struggle with green pools, broken pumps, and contractors
            who ghosted them mid-summer, we saw a gap. The Gold Coast deserved a pool service that
            actually showed up, communicated clearly, and treated pools like the family asset they are.
          </p>
        </div>
        <div class="card p-8">
          <h2 class="font-display text-[28px] leading-tight mb-3">Where we are now</h2>
          <p class="text-ink-soft leading-relaxed">
            We're a small, hands-on team building Pool Pals the right way — reliable weekly service,
            honest advice, and same-day help when something goes wrong. Fully licensed and insured,
            and growing across the Coast one sparkling pool at a time.
          </p>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        {[
          { n: '2025', l: 'Founded on the Coast' },
          { n: 'Same-day', l: 'Emergency response' },
          { n: '22-pt', l: 'Service checklist' },
          { n: '100%', l: 'Licensed & insured' },
        ].map((s) => (
          <div class="text-center p-6 rounded-[14px] bg-[var(--color-bg-alt)]">
            <div class="font-display text-[40px] leading-none mb-1.5">{s.n}</div>
            <div class="text-sm text-ink-soft">{s.l}</div>
          </div>
        ))}
      </div>

      <!-- Team -->
      <h2 class="font-display text-[32px] mb-8">Meet the founders</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-20 h-20 rounded-xl bg-aqua-soft shrink-0 flex items-center justify-center text-[var(--color-aqua-deep)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Dave Harrison</h3>
            <p class="text-sm text-ink-mute mb-2">Co-founder & Head Technician</p>
            <p class="text-sm text-ink-soft leading-relaxed">
              Certified pool operator (CPO) with 15+ years in water treatment. Dave personally trains every new
              technician and still runs a route every Saturday because "that's when the best chats happen."
            </p>
          </div>
        </div>
        <div class="card p-6 flex gap-5 items-start">
          <div class="w-20 h-20 rounded-xl bg-aqua-soft shrink-0 flex items-center justify-center text-[var(--color-aqua-deep)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Marcus Chen</h3>
            <p class="text-sm text-ink-mute mb-2">Co-founder & Operations</p>
            <p class="text-sm text-ink-soft leading-relaxed">
              Ex-hospitality operations manager who brought scheduling discipline and customer service
              standards to an industry that sorely needed it. Marcus handles the tech, the routes, and the complaints.
            </p>
          </div>
        </div>
      </div>

      <!-- Values -->
      <div class="mt-16">
        <h2 class="font-display text-[32px] mb-8">What we believe</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { t: 'Show up', d: 'Same day, same time, same friendly face. No excuses.' },
            { t: 'Explain everything', d: 'You should understand your pool, not just pay for it.' },
            { t: 'Fix it right', d: 'No band-aid solutions. Do it properly or not at all.' },
          ].map((v) => (
            <div class="card p-6">
              <h3 class="font-display text-xl mb-2">{v.t}</h3>
              <p class="text-sm text-ink-soft leading-relaxed">{v.d}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
