---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';
import { iconMap } from '@/lib/icons';

const title = 'Pool Services — Gold Coast | Pool Pals';
const description = 'Weekly cleaning, chemical balancing, green pool recovery, equipment repairs, leak detection, and Form 23 pool safety certificates across the Gold Coast. No contracts.';
---

<BaseLayout title={title} description={description}>
  <section class="pt-16 pb-12">
    <div class="container-narrow">
      <div class="section-eyebrow eyebrow"><span class="dot"></span>Services</div>
      <h1 class="font-display text-[clamp(40px,5vw,72px)] leading-[1.02] mb-6">
        Everything your pool <span class="text-aqua-deep italic">needs.</span>
      </h1>
      <p class="text-lg text-ink-soft leading-relaxed max-w-[640px] mb-12">
        One team for the whole Coast — from weekly cleaning and water chemistry to leak detection,
        equipment, and Form 23 pool safety certificates. No upsells, no bait-and-switch, no
        "while I'm here" surprises.
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-narrow">
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((s) => {
          const Icon = iconMap[s.icon] ?? iconMap.Filter;
          return (
            <a href={`/services/${s.slug}`} class="card p-7 block hover:border-[var(--color-aqua)] transition-colors group">
              <div class="flex items-start justify-between mb-4">
                <div class="h-12 w-12 rounded-lg bg-aqua-soft flex items-center justify-center text-aqua-deep">
                  <Icon className="h-6 w-6" />
                </div>
                <span class="text-sm font-medium text-[var(--color-aqua-deep)]">{s.price}</span>
              </div>
              <h2 class="font-display text-[22px] leading-tight mb-2 group-hover:text-[var(--color-aqua-deep)] transition-colors">{s.title}</h2>
              <p class="text-[15px] text-ink-soft leading-relaxed mb-4">{s.blurb}</p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-aqua-deep">
                Learn more
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              </span>
            </a>
          );
        })}
      </div>

      <div class="mt-12 text-center">
        <p class="text-ink-soft mb-4">Not sure which service you need?</p>
        <button class="btn btn-aqua" data-action="quote">
          Get a free recommendation
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
